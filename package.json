{
  "name": "table-tennis-results-tracker",
  "version": "1.5.0",
  "description": "An Angular web app for tracking table tennis results",
  "scripts": {
    "ng": "ng",
    "start": "ng serve",
    "build": "ng build",
    "watch": "ng build --watch --configuration development",
    "format": "prettier --write ./data ./src",
    "format:check": "prettier --check ./data ./src",
    "lint": "ng lint",
    "test": "ng test",
    "test:ci": "ng test --no-watch --no-progress --browsers=ChromeHeadless",
    "test:coverage": "ng test --no-watch --no-progress --browsers=ChromeHeadless --code-coverage",
    "prepare": "husky"
  },
  "private": true,
  "dependencies": {
    "@angular/animations": "^19.2.17",
    "@angular/cdk": "^19.2.19",
    "@angular/common": "^19.2.0",
    "@angular/compiler": "^19.2.0",
    "@angular/core": "^19.2.0",
    "@angular/forms": "^19.2.0",
    "@angular/material": "^19.2.19",
    "@angular/platform-browser": "^19.2.0",
    "@angular/platform-browser-dynamic": "^19.2.0",
    "@angular/router": "^19.2.0",
    "rxjs": "~7.8.0",
    "tslib": "^2.3.0",
    "zone.js": "~0.15.0"
  },
  "devDependencies": {
    "@angular-devkit/build-angular": "^19.2.14",
    "@angular/cli": "^19.2.14",
    "@angular/compiler-cli": "^19.2.0",
    "@types/jasmine": "~5.1.0",
    "angular-eslint": "19.8.1",
    "eslint": "^9.39.1",
    "eslint-config-prettier": "^9.1.0",
    "eslint-plugin-prettier": "^5.2.1",
    "husky": "^9.1.6",
    "jasmine-core": "~5.6.0",
    "karma": "~6.4.0",
    "karma-chrome-launcher": "~3.2.0",
    "karma-coverage": "~2.2.0",
    "karma-jasmine": "~5.1.0",
    "karma-jasmine-html-reporter": "~2.1.0",
    "prettier": "^3.3.3",
    "typescript": "~5.7.2",
    "typescript-eslint": "8.46.4"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/matejb6/table-tennis-results-tracker.git"
  },
  "bugs": {
    "url": "https://github.com/matejb6/table-tennis-results-tracker/issues"
  },
  "keywords": [
    "matejb6",
    "Angular",
    "Forms",
    "Results",
    "Assignment"
  ],
  "author": {
    "name": "Matej Buljan",
    "email": "matejb6@icloud.com"
  },
  "license": "MIT",
  "engines": {
    "node": "^18.19.1 || ^20.11.1 || ^22.0.0"
  }
}
